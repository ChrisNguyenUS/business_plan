{
  "name": "ContactSubmission",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Contact's full name"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "service_type": {
      "type": "string",
      "enum": [
        "tax",
        "insurance",
        "immigration",
        "ai",
        "general"
      ],
      "description": "Service requested"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "contacted",
        "resolved"
      ],
      "description": "Submission status"
    }
  },
  "required": [
    "full_name",
    "email",
    "service_type",
    "message"
  ]
}