{
  "name": "Case",
  "type": "object",
  "properties": {
    "client_email": {
      "type": "string",
      "description": "Client email address"
    },
    "client_name": {
      "type": "string",
      "description": "Client full name"
    },
    "client_phone": {
      "type": "string",
      "description": "Client phone number"
    },
    "case_type": {
      "type": "string",
      "enum": [
        "form",
        "bundle"
      ],
      "description": "Single form or bundle"
    },
    "form_code": {
      "type": "string",
      "enum": [
        "I-90",
        "I-130",
        "I-485",
        "I-751",
        "I-765",
        "I-131",
        "N-400",
        "N-600",
        "I-864",
        "I-912",
        "AR-11",
        "FOIA",
        "TRANSLATION"
      ],
      "description": "USCIS form number"
    },
    "bundle_code": {
      "type": "string",
      "enum": [
        "marriage-gc",
        "family-petition-consular",
        "citizenship-fast-track",
        "gc-renewal-travel-doc",
        "remove-conditions-ead"
      ],
      "description": "Bundle identifier"
    },
    "current_status": {
      "type": "string",
      "enum": [
        "intake",
        "docs-pending",
        "prep-in-progress",
        "ready-to-file",
        "filed-with-uscis",
        "noa-received",
        "case-update",
        "completed",
        "referred-out",
        "cancelled"
      ],
      "description": "Current case status"
    },
    "uscis_receipt_number": {
      "type": "string",
      "description": "USCIS receipt number (e.g. IOE1234567890)"
    },
    "service_fee_cents": {
      "type": "number",
      "description": "Our service fee in cents"
    },
    "uscis_fee_cents": {
      "type": "number",
      "description": "USCIS filing fee in cents"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "quoted",
        "invoiced",
        "paid",
        "refunded"
      ],
      "description": "Payment status"
    },
    "internal_notes": {
      "type": "string",
      "description": "Admin-only internal notes"
    },
    "priority_date": {
      "type": "string",
      "description": "USCIS priority date"
    },
    "filed_at": {
      "type": "string",
      "description": "Date filed with USCIS (ISO)"
    },
    "completed_at": {
      "type": "string",
      "description": "Date case completed (ISO)"
    },
    "review_requested": {
      "type": "boolean",
      "description": "Whether review has been requested"
    }
  },
  "required": [
    "client_email",
    "client_name",
    "case_type",
    "current_status"
  ]
}