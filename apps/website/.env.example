# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=MannaOS <notifications@mannaos.com>

# ─── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mannaos.com
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/mannaos

# ─── Google Analytics 4 ────────────────────────────────────────
# Create a GA4 property at analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Meta Pixel + Conversions API ──────────────────────────────
# business.facebook.com → Events Manager → Data Sources → Pixel
# Pixel ID is public (rendered in HTML), so a single NEXT_PUBLIC_ var is fine.
NEXT_PUBLIC_META_PIXEL_ID=
# Pixel → Settings → Conversions API → Generate Access Token (server-only, sensitive)
META_CAPI_ACCESS_TOKEN=
# Optional: Test Events code (remove for production)
# Events Manager → Test Events tab
META_CAPI_TEST_EVENT_CODE=
